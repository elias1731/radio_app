<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  IgnorableNamespaces="uap uap3">

  <Identity
    Name="HeyFordy.Radio"
    Publisher="CN=Fordy"
    Version="1.0.0.0" />

  <Properties>
    <DisplayName>Fordy Radio</DisplayName>
    <PublisherDisplayName>Fordy</PublisherDisplayName>
    <Logo>Assets\StoreLogo.scale-100.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Universal" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
    <TargetDeviceFamily Name="Windows.Xbox" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
  </Dependencies>

  <Resources>
    <Resource Language="de-DE" />
  </Resources>

  <Applications>
    <Application
      Id="App"
      StartPage="https://heyfordy.dev/radio/index.html">
      
      <uap:VisualElements
        DisplayName="𝓕𝓸𝓻𝓭𝔂•Radio"
        Description="Web Radio Player"
        BackgroundColor="#000000"
        Square150x150Logo="Assets\Square150x150Logo.scale-100.png"
        Square44x44Logo="Assets\Square44x44Logo.scale-100.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.scale-100.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.scale-100.png" />
      </uap:VisualElements>
      
      <uap:ApplicationContentUriRules>
        <uap:Rule Match="https://heyfordy.dev/" Type="include" WindowsRuntimeAccess="all" />
        <uap:Rule Match="https://api.heyfordy.dev/" Type="include" />
      </uap:ApplicationContentUriRules>
    </Application>
  </Applications>

  <Capabilities>
    <Capability Name="internetClient" />
    <uap3:Capability Name="backgroundMediaPlayback" />
  </Capabilities>
</Package>